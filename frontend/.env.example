# Copie para `.env.local` (não commitar).

# Obrigatório: token de leitura em https://huggingface.co/settings/tokens
HUGGING_FACE_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Opcional: modelo de classificação **já fine-tuned** e publicado no Hub (sequence classification).
# O checkpoint neuralmind/bert-base-portuguese-cased é pré-treino (MLM); não substitui o classificador do TCC.
# HF_CLASSIFIER_MODEL_ID=seu_usuario/bertimbau-juris-binario

# Opcional: modelo de embeddings (padrão Legal-BERTimbau STS).
# HF_EMBEDDING_MODEL=rufimelo/Legal-BERTimbau-sts-large-ma-v3

# Limiar de alerta: cosseno máximo abaixo deste valor dispara alerta (ajuste após calibrar).
# SIMILARITY_ALERT_THRESHOLD=0.38
